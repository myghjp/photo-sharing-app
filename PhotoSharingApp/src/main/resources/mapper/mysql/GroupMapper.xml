<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="portfolio.PhotoSharingApp.repository.GroupMapper">

	<resultMap type="portfolio.PhotoSharingApp.entity.Group" id="GroupsTable">
		<id column="id" property="id" />
		<result column="group_name" property="groupName" />
		<result column="account_id" property="accountId" />
		<result column="create_date_time" property="createDateTime" />
		<association property="account" resultMap="AccountsTable" columnPrefix="accounts_"/>
	</resultMap>
	
	<resultMap type="portfolio.PhotoSharingApp.entity.Account" id="AccountsTable">
		<id column="id" property="id" />
		<result column="user" property="username" />
		<result column="email_address" property="emailAddress" />
	</resultMap>
	
	
	<insert id="insert">
		insert into `groups`(
			 group_name
			,account_id
		)VALUES(
			 #{group.groupName}
			,#{group.accountId}
		)
	</insert>
	
	<delete id="delete">
		delete from `groups`
		where id = #{groupId}
	</delete>
	
	<!-- ーーーーーーーーーーーーーーーーーーーー -->
	
	<select id="selectGroups" resultMap="GroupsTable">
		select distinct groups.id
			,group_name
			,groups.account_id
			,groups.create_date_time
		from `groups`
			left join groups_members
			on groups.id = groups_members.group_id
		where groups.account_id = #{id}
			or groups_members.account_id = #{id}
	</select>
	
	<select id="selectGroup" resultMap="GroupsTable">
		select *
		from `groups`
		where id = #{groupId}
	</select>
	
	<select id="selectByAccounts" resultMap="GroupsTable">
		select accounts.user as accounts_user
			,accounts.email_address as accounts_email_address
		from `groups`
			left join accounts
			on groups.account_id = accounts.id
		where groups.id = #{groupId}
	</select>
	
	<select id="selectByGroupName" resultType="String">
		select group_name
		from `groups`
		where group_name = #{groupName}
	</select>
	
	<select id="selectByGroupsAccountId" resultType="Integer">
		select account_id
		from `groups`
		where id = #{groupId}
	</select>

	<select id="selectByAccountId" resultType="Integer">
		select distinct account_id
		from `groups`
		where account_id = #{id}
	</select>
	
</mapper>